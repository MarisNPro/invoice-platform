# ── Database ──────────────────────────────────────────────────────────────────
# Local development:
DATABASE_URL=postgresql://invoice:invoice@localhost:5432/invoice_platform
DIRECT_URL=postgresql://invoice:invoice@localhost:5432/invoice_platform

# Production (Supabase eu-central-1 Frankfurt) — replace YOURPROJECT and PASSWORD:
# DATABASE_URL=postgresql://postgres.YOURPROJECT:PASSWORD@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true
# DIRECT_URL=postgresql://postgres.YOURPROJECT:PASSWORD@aws-0-eu-central-1.pooler.supabase.com:5432/postgres

# ── Redis ─────────────────────────────────────────────────────────────────────
# Local development:
REDIS_URL=redis://localhost:6379
# Production (Upstash eu-central-1 Frankfurt) — replace PASSWORD and DB:
# REDIS_URL=rediss://default:PASSWORD@eu1-YOURDB.upstash.io:6379
REDIS_TTL_SECONDS=3600

# ── Auth (Supabase Auth — active provider) ────────────────────────────────────
# Project base URL drives the JWT issuer + JWKS (apps/api/src/auth/supabase-jwt.guard.ts).
SUPABASE_URL=https://YOURPROJECT.supabase.co
# Local dev shortcut: send `x-dev-tenant-id: <uuid>` to bypass auth (non-prod only).

# ── Keycloak (LEGACY — retired) ───────────────────────────────────────────────
# Migration-only fallback in the composite guard; leave unset. Do not run Keycloak.
# KEYCLOAK_URL=
# KEYCLOAK_REALM=
# KEYCLOAK_CLIENT_ID=
# KEYCLOAK_CLIENT_SECRET=

# LV/LT company search uses Postgres pg_trgm (no Elasticsearch) — nothing to set.

# ── S3 / MinIO ────────────────────────────────────────────────────────────────
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=invoice-platform
S3_REGION=us-east-1
S3_FORCE_PATH_STYLE=true

# ── API ───────────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development
API_GLOBAL_PREFIX=api/v1
CORS_ORIGINS=http://localhost:3000

# ── Worker ────────────────────────────────────────────────────────────────────
WORKER_CONCURRENCY=5

# ── Company Registry Sync ─────────────────────────────────────────────────────
# Latvia UR bulk CSV URL (updated nightly)
LV_UR_CSV_URL=https://ur.gov.lv/en/open-data/companies.csv
# Lithuania RC bulk CSV URL
LT_RC_CSV_URL=https://www.registrucentras.lt/jar/p/doc/jar_iregistruoti_statiniai.csv

# ── External Company APIs ─────────────────────────────────────────────────────
# Finland PRH (no auth required for open data)
PRH_API_URL=https://avoindata.prh.fi/opendata-ytj-api/v3
# PRH endpoint used by CompanyService: GET /companies?name={q}&maxResults={limit}
# Estonia Äriregister
ARIREGISTER_API_URL=https://ariregister.rik.ee/api

# ── Mail (local dev: MailHog) ─────────────────────────────────────────────────
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_FROM=noreply@invoiceplatform.local

# ── Cloud archive token encryption ───────────────────────────────────────────
# Generate: openssl rand -hex 32
ARCHIVE_ENCRYPTION_KEY=

# ── Cloud archive — OAuth app credentials ─────────────────────────────────────
# Google Drive: https://console.cloud.google.com/ → APIs & Services → Credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:4000/api/v1/archive/callback/google_drive

# Dropbox: https://www.dropbox.com/developers/apps
DROPBOX_APP_KEY=
DROPBOX_APP_SECRET=
DROPBOX_REDIRECT_URI=http://localhost:4000/api/v1/archive/callback/dropbox

# OneDrive: https://portal.azure.com/ → App registrations
ONEDRIVE_CLIENT_ID=
ONEDRIVE_CLIENT_SECRET=
ONEDRIVE_REDIRECT_URI=http://localhost:4000/api/v1/archive/callback/onedrive

# Frontend URL (used for post-OAuth redirect)
FRONTEND_URL=http://localhost:3000

# ── Anthropic / Claude AI ─────────────────────────────────────────────────────
# Get your key at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# ── MCP Server ───────────────────────────────────────────────────────────────
# Base URL the MCP server uses to call the invoice API
APP_BASE_URL=http://localhost:4000
# Port the MCP server listens on
MCP_PORT=4020
# JSON object mapping API key → orgId, e.g.: {"sk_live_abc":"uuid","ro_readonly":"uuid"}
MCP_API_KEYS={}
# Dev shortcut key (simpler than editing MCP_API_KEYS in dev)
MCP_DEV_KEY=
MCP_DEV_ORG_ID=
