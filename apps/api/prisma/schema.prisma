// ============================================================
// EU Invoice Platform — Prisma Schema
// EN 16931 compliant, multi-tenant, PostgreSQL 16
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Enums ────────────────────────────────────────────────────────────────────

enum Role {
  ADMIN
  ACCOUNTANT
  VIEWER
}

enum InvoiceType {
  INVOICE
  CREDIT_NOTE
  DEBIT_NOTE
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  OVERDUE
  CANCELLED
  VOID
}

enum AddressType {
  BILLING
  SHIPPING
  REGISTERED
}

enum PaymentMethod {
  BANK_TRANSFER
  CREDIT_CARD
  DIRECT_DEBIT
  CASH
  OTHER
}

enum ImportStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum Plan {
  FREE
  STARTER
  BUSINESS
  PROFESSIONAL
}

enum CloudProvider {
  GOOGLE_DRIVE
  DROPBOX
  ONEDRIVE
}

enum TransmissionChannel {
  EMAIL
  WHATSAPP
  PEPPOL
  DUNNING
}

enum TransmissionStatus {
  PENDING
  SENT
  FAILED
  BOUNCED
}

// ── Tenant ───────────────────────────────────────────────────────────────────

model Tenant {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  slug      String   @unique
  vatNumber String?
  country   String   @db.Char(2)
  locale    String   @default("en") @db.VarChar(5)

  // ── Billing / plan ────────────────────────────────────────────────────────
  plan                 Plan      @default(FREE)
  planStartedAt        DateTime?
  planExpiresAt        DateTime?

  // ── Monthly usage counters ────────────────────────────────────────────────
  /// Running AI spend this calendar month, in euro cents
  monthlyAiSpendCents  Int @default(0)
  /// Soft cap in euro cents; -1 = unlimited (PROFESSIONAL)
  monthlyAiSpendLimit  Int @default(200)
  /// Invoices created this calendar month
  monthlyInvoiceCount  Int @default(0)
  /// Invoice creation cap; -1 = unlimited
  monthlyInvoiceLimit  Int @default(50)
  /// Claude API calls this calendar month
  monthlyAiCallCount   Int @default(0)
  /// Claude API call cap; -1 = unlimited
  monthlyAiCallLimit   Int @default(-1)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users           User[]
  invoices        Invoice[]
  contacts        Contact[]
  products        Product[]
  taxRates        TaxRate[]
  invoiceCounters InvoiceCounter[]
  bankAccounts    BankAccount[]
  importArchives  ImportArchive[]
  auditLogs       AuditLog[]
  apiKeys         ApiKey[]
  cloudArchives   CloudArchive[]

  @@map("tenants")
}

// ── User ─────────────────────────────────────────────────────────────────────

model User {
  id          String    @id @default(uuid()) @db.Uuid
  tenantId    String    @db.Uuid
  keycloakId  String    @unique
  email       String
  name        String
  firstName   String?
  lastName    String?
  role        Role      @default(VIEWER)
  isActive    Boolean   @default(true)
  lastLoginAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  tenant   Tenant    @relation(fields: [tenantId], references: [id])
  invoices Invoice[]

  @@unique([tenantId, email])
  @@index([keycloakId])
  @@index([isActive])
  @@map("users")
}

// ── Contact (customer / supplier) ────────────────────────────────────────────

model Contact {
  id             String  @id @default(uuid()) @db.Uuid
  tenantId       String  @db.Uuid
  name           String
  businessId     String? // national business registration number
  vatNumber      String?
  country        String  @db.Char(2)
  email          String?
  phone          String?
  iban           String?
  bic            String?
  isSupplier     Boolean @default(false)
  isCustomer     Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant         Tenant    @relation(fields: [tenantId], references: [id])
  addresses      Address[]
  buyerInvoices  Invoice[] @relation("BuyerContact")
  sellerInvoices Invoice[] @relation("SellerContact")
  apiKeys        ApiKey[]

  @@index([tenantId, country])
  @@index([tenantId, vatNumber])
  @@map("contacts")
}

model Address {
  id         String      @id @default(uuid()) @db.Uuid
  contactId  String      @db.Uuid
  type       AddressType @default(BILLING)
  street     String
  city       String
  postalCode String
  country    String      @db.Char(2)
  isDefault  Boolean     @default(false)
  createdAt  DateTime    @default(now())

  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@map("addresses")
}

// ── Product catalogue ─────────────────────────────────────────────────────────

model Product {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @db.Uuid
  code        String
  name        String
  description String?
  unit        String   @default("PCS") @db.VarChar(10)
  unitPrice   Decimal  @db.Decimal(18, 6)
  taxRateId   String?  @db.Uuid
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant      Tenant        @relation(fields: [tenantId], references: [id])
  taxRate     TaxRate?      @relation(fields: [taxRateId], references: [id])
  invoiceLines InvoiceLine[]

  @@unique([tenantId, code])
  @@map("products")
}

// ── Tax rates (EN 16931 category codes) ──────────────────────────────────────

model TaxRate {
  id           String  @id @default(uuid()) @db.Uuid
  tenantId     String  @db.Uuid
  name         String
  /// Fractional rate e.g. 0.2000 = 20%
  rate         Decimal @db.Decimal(5, 4)
  /// EN 16931 tax category code: S, Z, E, AE, K, G, O, L, M
  categoryCode String  @db.VarChar(2)
  isDefault    Boolean @default(false)

  tenant       Tenant        @relation(fields: [tenantId], references: [id])
  products     Product[]
  invoiceLines InvoiceLine[]

  @@map("tax_rates")
}

// ── Atomic invoice counter ────────────────────────────────────────────────────
// The next_invoice_number() PG function does atomic UPSERT on this table.

model InvoiceCounter {
  id       String @id @default(uuid()) @db.Uuid
  tenantId String @db.Uuid
  prefix   String @db.VarChar(10)
  year     Int    @db.SmallInt
  last     Int    @default(0)

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, prefix, year])
  @@map("invoice_counters")
}

// ── Invoice ───────────────────────────────────────────────────────────────────

model Invoice {
  id             String        @id @default(uuid()) @db.Uuid
  tenantId       String        @db.Uuid
  number         String
  type           InvoiceType   @default(INVOICE)
  status         InvoiceStatus @default(DRAFT)
  sellerId       String        @db.Uuid
  buyerId        String        @db.Uuid
  issuedAt       DateTime      @db.Date
  dueAt          DateTime      @db.Date
  currencyCode   String        @default("EUR") @db.Char(3)
  buyerReference String?
  orderReference String?
  projectCode    String?
  note           String?       @db.Text

  // EN 16931 UBL fields
  ublXml         String?       @db.Text
  pdfKey         String?       // S3 object key

  // Denormalised totals (recomputed by trigger or service)
  subtotal       Decimal       @default(0) @db.Decimal(18, 2)
  taxAmount      Decimal       @default(0) @db.Decimal(18, 2)
  total          Decimal       @default(0) @db.Decimal(18, 2)

  // EN 16931 BT-20 payment terms note and document language
  paymentTermsNote String?       @db.Text
  language         String?       @default("en") @db.VarChar(5)

  createdById    String?       @db.Uuid
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  tenant        Tenant               @relation(fields: [tenantId], references: [id])
  seller        Contact              @relation("SellerContact", fields: [sellerId], references: [id])
  buyer         Contact              @relation("BuyerContact", fields: [buyerId], references: [id])
  createdBy     User?                @relation(fields: [createdById], references: [id])
  lines         InvoiceLine[]
  vatBreakdowns InvoiceVatBreakdown[]
  payments      Payment[]
  attachments   Attachment[]
  auditLogs     AuditLog[]
  transmissions InvoiceTransmission[]

  @@unique([tenantId, number])
  @@index([tenantId, status])
  @@index([tenantId, buyerId])
  @@index([tenantId, dueAt])
  @@map("invoices")
}

model InvoiceLine {
  id          String   @id @default(uuid()) @db.Uuid
  invoiceId   String   @db.Uuid
  lineNumber  Int      @db.SmallInt
  productId   String?  @db.Uuid
  description String
  quantity    Decimal  @db.Decimal(18, 6)
  unit        String   @default("PCS") @db.VarChar(10)
  unitPrice   Decimal  @db.Decimal(18, 6)
  /// Discount fraction 0–1
  discount    Decimal  @default(0) @db.Decimal(5, 4)
  taxRateId   String?  @db.Uuid
  lineTotal   Decimal  @db.Decimal(18, 2)
  taxAmount   Decimal  @db.Decimal(18, 2)
  /// EN 16931 line note
  note        String?

  invoice Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id])
  taxRate TaxRate? @relation(fields: [taxRateId], references: [id])

  @@map("invoice_lines")
}

// ── VAT breakdown (one row per tax rate on an invoice) ───────────────────────
// EN 16931 BG-23 / UBL TaxTotal/TaxSubtotal

model InvoiceVatBreakdown {
  id              String  @id @default(uuid()) @db.Uuid
  invoiceId       String  @db.Uuid
  /// EN 16931 BT-119 — tax category code: S, Z, E, AE, K, G, O, L, M
  vatCategoryCode String  @db.VarChar(2)
  /// BT-120 — VAT rate as percentage e.g. 21.00
  vatRatePercent  Decimal @db.Decimal(5, 2)
  /// BT-116 — net taxable amount for this rate group
  taxableAmount   Decimal @db.Decimal(18, 2)
  /// BT-117 — VAT amount for this rate group
  taxAmount       Decimal @db.Decimal(18, 2)

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
  @@map("invoice_vat_breakdowns")
}

// ── Payment ───────────────────────────────────────────────────────────────────

model Payment {
  id        String        @id @default(uuid()) @db.Uuid
  invoiceId String        @db.Uuid
  amount    Decimal       @db.Decimal(18, 2)
  method    PaymentMethod @default(BANK_TRANSFER)
  reference String?
  paidAt    DateTime
  createdAt DateTime      @default(now())

  invoice Invoice @relation(fields: [invoiceId], references: [id])

  @@map("payments")
}

// ── Bank account ──────────────────────────────────────────────────────────────

model BankAccount {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @db.Uuid
  iban      String
  bic       String?
  bankName  String?
  currency  String   @default("EUR") @db.Char(3)
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@map("bank_accounts")
}

// ── Attachment ────────────────────────────────────────────────────────────────

model Attachment {
  id        String   @id @default(uuid()) @db.Uuid
  invoiceId String   @db.Uuid
  fileName  String
  mimeType  String
  s3Key     String
  sizeBytes Int
  createdAt DateTime @default(now())

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@map("attachments")
}

// ── Audit log ─────────────────────────────────────────────────────────────────

model AuditLog {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @db.Uuid
  invoiceId String?  @db.Uuid
  userId    String?
  action    String   @db.VarChar(64)
  payload   Json?
  ipAddress String?  @db.VarChar(45)
  createdAt DateTime @default(now())

  tenant  Tenant   @relation(fields: [tenantId], references: [id])
  invoice Invoice? @relation(fields: [invoiceId], references: [id])

  @@index([tenantId, createdAt])
  @@index([invoiceId])
  @@map("audit_logs")
}

// ── Invoice transmission log ──────────────────────────────────────────────────

model InvoiceTransmission {
  id                String              @id @default(uuid()) @db.Uuid
  invoiceId         String              @db.Uuid
  channel           TransmissionChannel
  status            TransmissionStatus  @default(PENDING)
  /// Email address, phone number, or PEPPOL participant ID
  recipientEndpoint String
  /// Provider message ID (Resend ID, SMTP messageId, etc.)
  providerMessageId String?
  /// BullMQ job ID for status tracking
  jobId             String?
  sentAt            DateTime?
  failedAt          DateTime?
  errorMessage      String?             @db.Text
  createdAt         DateTime            @default(now())

  invoice Invoice @relation(fields: [invoiceId], references: [id])

  @@index([invoiceId])
  @@map("invoice_transmissions")
}

// ── Client API keys (read-only, optionally customer-scoped) ──────────────────

model ApiKey {
  id         String    @id @default(uuid()) @db.Uuid
  tenantId   String    @db.Uuid
  /// Optional: restrict this key to a single buyer contact
  contactId  String?   @db.Uuid
  name       String
  /// SHA-256 hex digest of the plain key — never stored in plain text
  keyHash    String    @unique @db.VarChar(64)
  /// First 12 chars of the plain key for UI display (e.g. "ro_00000000_a")
  keyPrefix  String    @db.VarChar(12)
  isActive   Boolean   @default(true)
  lastUsedAt DateTime?
  createdAt  DateTime  @default(now())

  tenant  Tenant   @relation(fields: [tenantId], references: [id])
  contact Contact? @relation(fields: [contactId], references: [id])

  @@index([keyHash])
  @@index([tenantId, isActive])
  @@map("api_keys")
}

// ── Cloud archive integration ─────────────────────────────────────────────────

model CloudArchive {
  id             String        @id @default(uuid()) @db.Uuid
  tenantId       String        @db.Uuid
  provider       CloudProvider
  /// AES-256-CBC encrypted; format: iv_hex:ciphertext_hex
  accessToken    String        @db.Text
  /// AES-256-CBC encrypted; format: iv_hex:ciphertext_hex
  refreshToken   String        @db.Text
  tokenExpiresAt DateTime?
  folderPath     String        @default("/InvoiceArchive")
  folderId       String?
  isActive       Boolean       @default(true)
  lastSyncAt     DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, provider])
  @@index([tenantId, isActive])
  @@map("cloud_archives")
}

// ── Import archive ────────────────────────────────────────────────────────────

model ImportArchive {
  id            String       @id @default(uuid()) @db.Uuid
  tenantId      String       @db.Uuid
  fileName      String
  s3Key         String
  status        ImportStatus @default(PENDING)
  recordCount   Int?
  errorCount    Int?
  errors                 Json?
  extractedData          Json?
  confirmedInvoiceNumber String?
  createdAt              DateTime     @default(now())
  completedAt            DateTime?

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId, status])
  @@map("import_archives")
}
