{
  "name": "@invoice/api",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "nest build",
    "dev": "nest start --watch",
    "start": "node dist/main",
    "lint": "eslint \"{src,test}/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "db:generate": "prisma generate --schema=./prisma/schema.prisma",
    "db:migrate": "dotenv -e ../../.env -- prisma migrate deploy --schema=./prisma/schema.prisma",
    "db:migrate:dev": "dotenv -e ../../.env -- prisma migrate dev --schema=./prisma/schema.prisma",
    "db:seed": "dotenv -e ../../.env -- prisma db seed",
    "db:studio": "dotenv -e ../../.env -- prisma studio --schema=./prisma/schema.prisma",
    "db:reset": "dotenv -e ../../.env -- prisma migrate reset --schema=./prisma/schema.prisma --force",
    "sync:lv": "ts-node --project tsconfig.json src/company/sync-runner.ts lv",
    "sync:lt": "ts-node --project tsconfig.json src/company/sync-runner.ts lt",
    "sync:all": "ts-node --project tsconfig.json src/company/sync-runner.ts all"
  },
  "prisma": {
    "seed": "ts-node --transpile-only --project tsconfig.json prisma/seed.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.30.0",
    "@elastic/elasticsearch": "^8.13.1",
    "@invoice/ubl-builder": "workspace:*",
    "@nestjs/axios": "^3.0.2",
    "@nestjs/common": "^10.3.10",
    "@nestjs/config": "^3.2.3",
    "@nestjs/core": "^10.3.10",
    "@nestjs/platform-fastify": "^10.3.10",
    "@nestjs/terminus": "^10.2.3",
    "@prisma/client": "^5.16.0",
    "axios": "^1.7.2",
    "bullmq": "^5.8.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "csv-parse": "^5.5.6",
    "fastify": "^4.28.1",
    "ioredis": "^5.4.1",
    "jose": "^5.4.1",
    "pdf-lib": "^1.17.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.2",
    "@nestjs/schematics": "^10.1.4",
    "@nestjs/testing": "^10.3.10",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.14.10",
    "jest": "^29.7.0",
    "prisma": "^5.16.0",
    "ts-jest": "^29.2.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.ts$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node",
    "passWithNoTests": true,
    "setupFiles": [
      "<rootDir>/test-setup.ts"
    ]
  }
}
