# ══════════════════════════════════════════════════════════════════════════════
# Invoice Platform — Production Environment Variables
# Copy to .env.production on your Hetzner server (never commit real values)
#
# Where to get each value is noted inline.
# ══════════════════════════════════════════════════════════════════════════════


# ── PostgreSQL (Supabase EU Frankfurt) ────────────────────────────────────────
# Project: app.supabase.com → Settings → Database → Connection string
# Use the "Transaction" pooler URL for the app (port 6543)
DATABASE_URL=postgresql://postgres.xxxx:password@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=10

# Use the "Session" pooler URL (port 5432) for Prisma migrate — needs long-lived connections
DIRECT_URL=postgresql://postgres.xxxx:password@aws-0-eu-central-1.pooler.supabase.com:5432/postgres


# ── Redis (Upstash EU — Frankfurt) ────────────────────────────────────────────
# console.upstash.com → Create Database → Frankfurt → Connect → .env
REDIS_URL=rediss://default:xxxx@eu1-xxxx.upstash.io:6380

# Cache TTL for company search results (seconds)
REDIS_TTL_SECONDS=3600


# ── Keycloak (self-hosted on Coolify / Hetzner) ───────────────────────────────
# Your Coolify Keycloak service URL + realm settings
# Realm → Clients → invoice-api → Credentials → Client Secret
KEYCLOAK_URL=https://auth.yourdomain.com
KEYCLOAK_REALM=invoice-platform
KEYCLOAK_CLIENT_ID=invoice-api
KEYCLOAK_CLIENT_SECRET=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx


# ── Hetzner Object Storage FSN1 (S3-compatible) ───────────────────────────────
# console.hetzner.com → Object Storage → Falkenstein → Create bucket
# Access keys: Object Storage → Access Keys → Generate
S3_ENDPOINT=https://fsn1.your-objectstorage.com
S3_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxx
S3_SECRET_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
S3_BUCKET=invoice-platform-prod
S3_REGION=eu-central-1
S3_FORCE_PATH_STYLE=true


# ── Email (Resend) ────────────────────────────────────────────────────────────
# resend.com → API Keys → Create API key
# Verify your domain in Resend → Domains before sending
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_USER=resend
SMTP_PASS=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
SMTP_FROM=invoices@yourdomain.com


# ── API settings ──────────────────────────────────────────────────────────────
# Allowed CORS origins (comma-separated, no trailing slash)
CORS_ORIGINS=https://app.yourdomain.com

API_GLOBAL_PREFIX=api/v1
NODE_ENV=production
PORT=4000


# ── Elasticsearch ─────────────────────────────────────────────────────────────
# Internal service — uses docker compose service name
ELASTICSEARCH_URL=http://elasticsearch:9200
ELASTICSEARCH_INDEX_COMPANIES=companies


# ── Worker settings ───────────────────────────────────────────────────────────
WORKER_CONCURRENCY=5

# Latvia UR bulk data (updated regularly — check ur.gov.lv for current URL)
LV_UR_CSV_URL=https://ur.gov.lv/en/open-data/companies.csv

# Lithuania RC bulk data (check registrucentras.lt for current URL)
LT_RC_CSV_URL=https://www.registrucentras.lt/jar/p/doc/jar_iregistruoti_statiniai.csv


# ── AI (optional — invoice assistant features) ────────────────────────────────
# anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx


# ── OAuth integrations (optional — for document import) ──────────────────────

# Google Drive / Google Workspace
# console.cloud.google.com → APIs & Services → Credentials → OAuth 2.0 Client ID
# Redirect URI: https://app.yourdomain.com/api/v1/oauth/google/callback
GOOGLE_CLIENT_ID=xxxxxxxxxxxx-xxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxxxxxxxxxxxxxx
GOOGLE_REDIRECT_URI=https://app.yourdomain.com/api/v1/oauth/google/callback

# Dropbox
# www.dropbox.com/developers/apps → Create app → OAuth 2
# Redirect URI: https://app.yourdomain.com/api/v1/oauth/dropbox/callback
DROPBOX_APP_KEY=xxxxxxxxxxxxxxxxxxxx
DROPBOX_APP_SECRET=xxxxxxxxxxxxxxxxxxxx
DROPBOX_REDIRECT_URI=https://app.yourdomain.com/api/v1/oauth/dropbox/callback

# Microsoft OneDrive
# portal.azure.com → App registrations → New registration
# API permissions: Files.ReadWrite, offline_access
# Redirect URI: https://app.yourdomain.com/api/v1/oauth/onedrive/callback
ONEDRIVE_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
ONEDRIVE_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ONEDRIVE_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
ONEDRIVE_REDIRECT_URI=https://app.yourdomain.com/api/v1/oauth/onedrive/callback
